# Anthropic API Key (get at console.anthropic.com)
ANTHROPIC_API_KEY=sk-ant-...

# Alpaca Markets API Keys (get free paper account at alpaca.markets)
ALPACA_API_KEY=PKXXXXXXXXXXXXXXXXXXXXXXXX
ALPACA_SECRET_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Alpaca URLs — paper trading (safe, no real money)
ALPACA_BASE_URL=https://paper-api.alpaca.markets
ALPACA_DATA_URL=https://data.alpaca.markets
ALPACA_WS_URL=wss://stream.data.alpaca.markets/v2/iex

# Server access token. Use a long random value and keep it private.
NEXUS_ADMIN_TOKEN=change-this-long-random-token
NEXUS_SESSION_HOURS=12
NEXUS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Server-side order guardrails.
NEXUS_MAX_ORDER_NOTIONAL=5000
NEXUS_MAX_ORDER_QTY=1000
NEXUS_AUTOTRADER_MAX_DAILY_TRADES=8

# Persistent AutoTrader state file lives in ./data by default.
# NEXUS_DATA_DIR=./data

# For LIVE trading: change ALPACA_BASE_URL and explicitly enable live orders.
# ALPACA_BASE_URL=https://api.alpaca.markets
# NEXUS_ENABLE_LIVE_TRADING=true

# Telegram notifications — bot token from @BotFather, chat_id from @userinfobot
TELEGRAM_BOT_TOKEN=123456:ABC-DEFxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TELEGRAM_CHAT_ID=your_numeric_chat_id

# Server port
PORT=3000
