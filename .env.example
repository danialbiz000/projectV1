# Anthropic API Key (get at console.anthropic.com)
ANTHROPIC_API_KEY=sk-ant-...

# Alpaca Markets API Keys (get free paper account at alpaca.markets)
ALPACA_API_KEY=PKXXXXXXXXXXXXXXXXXXXXXXXX
ALPACA_SECRET_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Alpaca URLs — paper trading (safe, no real money)
ALPACA_BASE_URL=https://paper-api.alpaca.markets
ALPACA_DATA_URL=https://data.alpaca.markets
ALPACA_WS_URL=wss://stream.data.alpaca.markets/v2/iex

# For LIVE trading: change only ALPACA_BASE_URL below (comment out paper, uncomment live)
# ALPACA_BASE_URL=https://api.alpaca.markets

# Server port
PORT=3000
